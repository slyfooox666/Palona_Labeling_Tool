{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palona.local/schemas/annotation-project-v1.json",
  "title": "Palona annotation project v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "interactions",
    "roi",
    "id_aliases",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "palona.annotation-project/v1" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "video_path",
        "contour_path",
        "video_fps",
        "video_width",
        "video_height",
        "frame_count",
        "duration_seconds",
        "available_categories"
      ],
      "properties": {
        "video_path": { "type": "string", "minLength": 1 },
        "contour_path": { "type": "string", "minLength": 1 },
        "video_file_size_bytes": { "type": "integer", "minimum": 1 },
        "contour_file_size_bytes": { "type": "integer", "minimum": 1 },
        "video_fps": { "type": "number", "exclusiveMinimum": 0 },
        "video_width": { "type": "integer", "minimum": 1 },
        "video_height": { "type": "integer", "minimum": 1 },
        "frame_count": { "type": "integer", "minimum": 1 },
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "available_categories": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "interactions": {
      "type": "array",
      "items": { "$ref": "#/$defs/interaction" }
    },
    "roi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["polygon", "blackout_enabled"],
      "properties": {
        "polygon": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "minItems": 3,
              "items": { "$ref": "#/$defs/point" }
            }
          ]
        },
        "blackout_enabled": { "type": "boolean" }
      }
    },
    "id_aliases": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "point": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "number", "minimum": 0, "maximum": 1 }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interaction_id", "interaction_type", "object_id_list", "start_time", "end_time"],
      "properties": {
        "interaction_id": { "type": "string", "minLength": 1 },
        "interaction_type": { "type": "string", "minLength": 1 },
        "object_id_list": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "start_time": { "type": "number", "minimum": 0 },
        "end_time": { "type": "number", "exclusiveMinimum": 0 },
        "start_frame": { "type": "integer", "minimum": 0 },
        "end_frame": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
